@using Sistema_de_Seguimiento_de_Solicitudes.Services.LoginServices
@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor

@inherits LayoutComponentBase
@inject NavigationManager NavigationManager
@inject AuthService AuthService

<div class="page">
    <main>
        <div class="top-row px-4" style="justify-content: flex-end; display: flex; align-items: center; gap: 15px;">

            <AuthorizeView Roles="ADMINISTRADOR, SUPERVISIÓN">
                <Authorized>
                    <button class="btn-modern-primary" @onclick="IrACrearUsuarios">
                        <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Class="icon-btn" />
                        Crear usuarios
                    </button>
                </Authorized>
            </AuthorizeView>

            <button class="btn btn-danger" @onclick="LogoutClicked">
                Cerrar sesión
            </button>

        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {

    private async Task LogoutClicked()
    {
        await AuthService.Logout();
        NavigationManager.NavigateTo("/Login", forceLoad: true);
    }

    private void IrACrearUsuarios()
    {
        NavigationManager.NavigateTo("/menu/modulo-solicitudes/CreacionUsuarios");
    }
}

<style>
    /* Diseño profesional para el botón de Crear Usuarios */
    .btn-modern-primary {
        background-color: #4f46e5; /* Azul índigo moderno */
        color: white;
        border: none;
        padding: 0.375rem 1rem; /* Padding equilibrado para igualar al btn-danger */
        border-radius: 0.375rem; /* Bordes suaves */
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px; /* Espacio perfecto entre el ícono y el texto */
        font-size: 1rem;
        font-weight: 500;
        white-space: nowrap; /* ESTO ES CLAVE: Evita que el texto baje a la segunda línea */
        transition: all 0.2s ease-in-out;
        box-shadow: 0 1px 2px rgba(0,0,0,0.05);
        cursor: pointer;
    }

        .btn-modern-primary:hover {
            background-color: #4338ca; /* Un azul ligeramente más oscuro al pasar el ratón */
            color: white;
            transform: translateY(-1px);
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }

        .btn-modern-primary:active {
            transform: translateY(0);
            box-shadow: none;
        }

        /* Candado estricto para que el ícono no se vuelva loco */
        .btn-modern-primary .icon-btn {
            width: 20px !important;
            height: 20px !important;
            color: white !important; /* Forza el color blanco para que contraste */
            fill: white !important;
            flex-shrink: 0; /* Impide que el contenedor aplaste o estire el ícono */
        }
</style>