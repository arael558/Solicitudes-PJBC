@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavManager

@attribute [Authorize]

<div class="sidebar-header">
    <a class="brand-logo" href="/menu">
        <span class="brand-icon-glow">
            <i class="bi bi-shield-check"></i>
        </span>
        <span class="brand-text">Modulo de solicitudes</span>
    </a>
    <button title="Menú de navegación" class="mobile-toggle" @onclick="ToggleNavMenu">
        <i class="bi bi-list"></i>
    </button>
</div>

<div class="@NavMenuCssClass nav-scrollable custom-scrollbar" @onclick="ToggleNavMenu">
    <nav class="flex-column nav-menu-container">

        @* ============================================================
           MÓDULO DE SOLICITUDES
           ============================================================ *@
        @if (EnModuloSolicitudes)
        {
            <div class="nav-section-title">Módulo Solicitudes</div>

            <div class="nav-item">
                <NavLink class="pro-nav-link" href="/menu/modulo-solicitudes/indice-expedientes">
                    <i class="bi bi-journal-text nav-icon"></i>
                    <span class="nav-text">Consulta</span>
                </NavLink>
            </div>

            <div class="nav-item">
                <NavLink class="pro-nav-link" href="/menu/modulo-solicitudes/Calendario">
                    <i class="bi bi-calendar-event nav-icon"></i>
                    <span class="nav-text">Calendario</span>
                </NavLink>
            </div>

            <div class="nav-item">
                <NavLink class="pro-nav-link" href="/menu/modulo-solicitudes/inicio-solicitudes">
                    <i class="bi bi-inboxes nav-icon"></i>
                    <span class="nav-text">Inicio Solicitudes</span>
                </NavLink>
            </div>

            <div class="nav-item">
                <NavLink class="pro-nav-link" href="/menu/modulo-solicitudes/historial-solicitudes">
                    <i class="bi bi-clock-history nav-icon"></i>
                    <span class="nav-text">Historial</span>
                </NavLink>
            </div>

            <AuthorizeView Roles="ADMINISTRADOR, Admin">
                <div class="nav-item mt-3">
                    <NavLink class="pro-nav-link danger-link" href="/menu/modulo-solicitudes/eliminar-expedientes">
                        <i class="bi bi-trash3 nav-icon"></i>
                        <span class="nav-text">Eliminar</span>
                    </NavLink>
                </div>
            </AuthorizeView>
        }

        @* ============================================================
           MÓDULO RECURSOS DE REVISIÓN
           ============================================================ *@
        @if (EnModuloRecursos)
        {
            <div class="nav-section-divider"></div>
            <div class="nav-section-title">Recursos de Revisión</div>

            <div class="nav-item">
                <NavLink class="pro-nav-link" href="/menu/recursos-revision/registro/expediente">
                    <i class="bi bi-folder2-open nav-icon"></i>
                    <span class="nav-text">Expediente</span>
                </NavLink>
            </div>

            <div class="nav-item">
                <NavLink class="pro-nav-link" href="/menu/recursos-revision/busqueda">
                    <i class="bi bi-search nav-icon"></i>
                    <span class="nav-text">Buscar Recursos</span>
                </NavLink>
            </div>

            <div class="nav-item">
                <NavLink class="pro-nav-link" href="/menu/recursos-revision/estadisticas">
                    <i class="bi bi-bar-chart nav-icon"></i>
                    <span class="nav-text">Estadísticas</span>
                </NavLink>
            </div>
        }

    </nav>
</div>

@code {
    private bool EnModuloSolicitudes => NavManager.Uri.Contains("/menu/modulo-solicitudes");
    private bool EnModuloRecursos => NavManager.Uri.Contains("/menu/recursos-revision");

    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu() => collapseNavMenu = !collapseNavMenu;
}

<style>
    /* ================= ULTRA-PREMIUM PALETTE ================= */
    :root {
        --sidebar-bg: #090e17; /* Ultra oscuro, casi negro abismal */
        --sidebar-border: #1e293b;
        --sidebar-text: #94a3b8;
        --sidebar-text-hover: #ffffff;
        --sidebar-active-text: #818cf8; /* Índigo neón */
        --sidebar-hover-bg: rgba(255, 255, 255, 0.04);
    }

    .sidebar {
        background-color: var(--sidebar-bg) !important;
        background-image: none !important;
        border-right: 1px solid var(--sidebar-border);
    }

    /* ================= HEADER Y LOGO ================= */
    .sidebar-header {
        height: 4.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 1.25rem;
        border-bottom: 1px solid rgba(255,255,255,0.05);
    }

    .brand-logo {
        display: flex;
        align-items: center;
        gap: 12px;
        text-decoration: none;
        color: white;
    }

    .brand-icon-glow {
        background: linear-gradient(135deg, #6366f1, #3b82f6);
        color: white;
        width: 30px;
        height: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        font-size: 1.1rem;
        box-shadow: 0 0 15px rgba(99, 102, 241, 0.4); /* Resplandor */
    }

    .brand-text {
        font-size: 1.1rem;
        font-weight: 700;
        letter-spacing: -0.01em;
        font-family: 'Inter', system-ui, sans-serif;
    }

    /* ================= CONTENEDOR PRINCIPAL ================= */
    .nav-scrollable {
        height: calc(100vh - 4.5rem);
        overflow-y: auto;
        padding: 1.5rem 0;
    }

    .nav-menu-container {
        padding: 0 0.75rem;
        display: flex;
        flex-direction: column;
        gap: 2px; /* Más pegaditos para un look más denso */
    }

    /* Títulos de Sección */
    .nav-section-title {
        font-size: 0.68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #475569;
        margin: 1.5rem 0 0.5rem 0.75rem;
    }

    .nav-section-divider {
        height: 1px;
        background-color: rgba(255,255,255,0.05);
        margin: 1rem 0.5rem;
    }

    /* ================= ENLACES DEL MENÚ ================= */
    .nav-item {
        width: 100%;
    }

    .pro-nav-link {
        display: flex;
        align-items: center;
        gap: 12px;
        height: 2.5rem; /* Más delgado y profesional (14px font, 40px height) */
        padding: 0 0.75rem;
        color: var(--sidebar-text);
        text-decoration: none;
        border-radius: 6px;
        font-size: 0.875rem; /* 14px - Tamaño estándar SaaS */
        font-weight: 500;
        transition: all 0.15s ease-in-out;
        font-family: 'Inter', system-ui, sans-serif;
        border: 1px solid transparent;
    }

    .nav-icon {
        font-size: 1.1rem;
        opacity: 0.6;
        transition: all 0.15s ease-in-out;
    }

    /* Hover */
    .pro-nav-link:hover {
        background-color: var(--sidebar-hover-bg);
        color: var(--sidebar-text-hover);
    }

        .pro-nav-link:hover .nav-icon {
            opacity: 1;
            color: var(--sidebar-text-hover);
        }

    /* ESTADO ACTIVO ULTRA PREMIUM (Gradiente + Barra) */
    .pro-nav-link.active {
        background: linear-gradient(90deg, rgba(99, 102, 241, 0.1) 0%, transparent 100%);
        color: var(--sidebar-active-text);
        font-weight: 600;
        position: relative;
    }

        /* La barrita de acento que aparece a la izquierda */
        .pro-nav-link.active::before {
            content: '';
            position: absolute;
            left: -0.75rem; /* La pega a la orilla del contenedor */
            top: 15%;
            height: 70%;
            width: 3px;
            background-color: var(--sidebar-active-text);
            border-radius: 0 4px 4px 0;
            box-shadow: 2px 0 8px rgba(99, 102, 241, 0.5);
        }

        .pro-nav-link.active .nav-icon {
            opacity: 1;
            color: var(--sidebar-active-text);
        }

    /* Enlace Danger (Eliminar) */
    .danger-link:hover {
        background-color: rgba(239, 68, 68, 0.08);
        color: #fca5a5;
    }

        .danger-link:hover .nav-icon {
            color: #fca5a5;
            opacity: 1;
        }

    /* ================= RESPONSIVO ================= */
    .mobile-toggle {
        background: transparent;
        border: 1px solid rgba(255,255,255,0.1);
        color: var(--sidebar-text);
        border-radius: 6px;
        width: 34px;
        height: 34px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        cursor: pointer;
    }

    @@media (min-width: 641px) {
        .mobile-toggle {
            display: none;
        }

        .collapse {
            display: block !important;
        }
    }

    @@media (max-width: 640px) {
        .sidebar-header {
            height: 4rem;
        }

        .brand-text {
            font-size: 1rem;
        }

        .collapse {
            display: none;
        }

            .collapse.show {
                display: block;
            }

        .nav-scrollable {
            height: calc(100vh - 4rem);
        }

        .pro-nav-link.active::before {
            left: 0;
        }
        /* Ajuste de la barrita en celular */
    }

    /* ================= SCROLLBAR ================= */
    .custom-scrollbar::-webkit-scrollbar {
        width: 5px;
    }

    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }

    .custom-scrollbar::-webkit-scrollbar-thumb {
        background-color: #1e293b;
        border-radius: 10px;
    }

        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background-color: #334155;
        }
</style>