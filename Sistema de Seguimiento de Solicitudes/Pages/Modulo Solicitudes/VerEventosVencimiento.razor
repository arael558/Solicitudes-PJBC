        border: none;
        padding: 0.5rem 1rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.85rem;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: all 0.2s ease;
        cursor: pointer;
    }

        .btn-export-excel:hover {
            background-color: #059669;
            transform: translateY(-1px);
            box-shadow: 0 4px 6px rgba(16, 185, 129, 0.25) !important;
        }

    /* ================= TABLA RADZEN PRO ================= */
    .vencimiento-grid {
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        overflow: hidden;
    }

    /* Limpieza de la tabla nativa */
    .rz-datagrid {
        border: none !important;
    }

    .rz-grid-table thead th {
        background-color: #f8fafc !important;
        color: #64748b !important;
        font-size: 0.75rem !important;
        font-weight: 700 !important;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        border-bottom: 1px solid #e2e8f0 !important;
        padding: 12px 8px !important;
    }

    .rz-grid-table td {
        padding: 12px 8px !important;
        border-bottom: 1px solid #f1f5f9 !important;
        font-size: 0.875rem;
    }

    .rz-datagrid-row:hover td {
        background-color: #f8fafc !important;
    }

    .date-text {
        color: #475569;
        font-weight: 500;
    }

    /* ================= BADGES (ETIQUETAS) ================= */
    .badge-tipo {
        background-color: #f1f5f9;
        color: #475569;
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 0.75rem;
        font-weight: 700;
        border: 1px solid #e2e8f0;
    }

    .badge-status {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 10px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.3px;
    }

        .badge-status.danger {
            background-color: #fef2f2;
            color: #ef4444;
            border: 1px solid #fecaca;
        }

        .badge-status.warning {
            background-color: #fffbeb;
            color: #d97706;
            border: 1px solid #fde68a;
        }

        .badge-status.warning-light {
            background-color: #fcf8ff;
            color: #b45309;
            border: 1px solid #fef08a;
        }

        .badge-status.success {
            background-color: #ecfdf5;
            color: #059669;
            border: 1px solid #a7f3d0;
        }

    /* ================= EMPTY STATE ================= */
    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        color: #94a3b8;
    }

        .empty-state i {
            font-size: 3rem;
            color: #10b981;
            margin-bottom: 1rem;
            display: block;
            opacity: 0.8;
        }

        .empty-state p {
            font-size: 1.1rem;
            font-weight: 500;
        }
</style>