@inherits ComponentBase

@using Sistema_de_Seguimiento_de_Solicitudes.Models
@using System.Text
@using System

@inject IJSRuntime JS

<div class="vencimiento-modal-container">
    <div class="modal-header-actions">
        <div>
            <h3 class="modal-title">Solicitudes próximas a vencer</h3>
            <p class="modal-subtitle">Monitorea el estado crítico de los expedientes.</p>
        </div>

        @if (Eventos.Any())
        {
            <button class="btn-export-excel shadow-sm" @onclick="ExportarExcel">
                <i class="bi bi-file-earmark-excel-fill"></i> Exportar a Excel
            </button>
        }
    </div>

    @if (Eventos.Any())
    {
        <div class="vencimiento-grid shadow-sm">
            <RadzenDataGrid Data="@Eventos"
                            TItem="EventoSolicitud"
                            ShowPagingSummary="true"
                            PagingSummaryFormat="Mostrando página {0} de {1} (Total: {2} registros)"
                            PageSize="10"
                            AllowPaging="true"
                            AllowSorting="true"
                            Responsive="true">
                <Columns>
                    <RadzenDataGridColumn TItem="EventoSolicitud" Title="N°" Width="60px" TextAlign="TextAlign.Center" Sortable="false">
                        <Template Context="evento">
                            <span class="text-muted fw-bold">@(Eventos.IndexOf(evento) + 1)</span>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="EventoSolicitud" Property="Title" Title="Folio / Solicitante" Width="300px">
                        <Template Context="evento">
                            <span class="fw-bold" style="color: #1e293b;">@evento.Title.Split("–").FirstOrDefault()?.Trim()</span>
                            @if (evento.Title.Contains("–"))
                            {
                                <span class="text-muted"> - @evento.Title.Split("–").LastOrDefault()?.Trim()</span>
                            }
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="EventoSolicitud" Property="TipoSolicitud" Title="Tipo" Width="100px" TextAlign="TextAlign.Center">
                        <Template Context="evento">
                            @if (!string.IsNullOrWhiteSpace(evento.TipoSolicitud))
                            {
                                <span class="badge-tipo">@evento.TipoSolicitud</span>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="EventoSolicitud" Property="End" Title="Límite" Width="120px" TextAlign="TextAlign.Center" SortOrder="SortOrder.Ascending">
                        <Template Context="evento">
                            <span class="date-text">@evento.End.ToString("dd/MM/yyyy")</span>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="EventoSolicitud" Title="Estado" Width="180px" TextAlign="TextAlign.Center" Sortable="false">
                        <Template Context="evento">
                            @{
                                var dias = CalcularDiasHabiles(DateTime.Now.Date, evento.End.Date);

                                if (dias < 0)
                                {
                                    <span class="badge-status danger">
                                        <i class="bi bi-x-circle-fill"></i> Venció hace @Math.Abs(dias) días
                                    </span>
                                }
                                else if (dias == 0)
                                {
                                    <span class="badge-status warning">
                                        <i class="bi bi-exclamation-circle-fill"></i> ¡Vence hoy!
                                    </span>
                                }
                                else if (dias <= 3)
                                {
                                    <span class="badge-status warning-light">
                                        <i class="bi bi-clock-fill"></i> Quedan @dias días
                                    </span>
                                }
                                else
                                {
                                    <span class="badge-status success">
                                        <i class="bi bi-check-circle-fill"></i> En tiempo (@dias días)
                                    </span>
                                }
                            }
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        </div>
    }
    else
    {
        <div class="empty-state">
            <i class="bi bi-check2-circle"></i>
            <p>¡Todo al día! No hay eventos próximos a vencer.</p>
        </div>
    }
</div>

@code {
    [Parameter] public List<EventoSolicitud> Eventos { get; set; } = new();

    protected override void OnInitialized()
    {
        // Forzamos a que la lista se ordene por la fecha límite de menor a mayor (más antiguo primero)
        if (Eventos != null && Eventos.Any())
        {
            Eventos = Eventos.OrderBy(e => e.End.Date).ToList();
        }
    }

    private async Task ExportarExcel()
    {
        var hora = DateTime.Now.ToString("HH꞉mm꞉ss");
        var nombre = $"Solicitudes_Vencimiento_{DateTime.Now:dd-MM-yyyy}_{hora}.csv";

        var xlsx = new StringBuilder();
        // Agregamos BOM para que Excel lea los acentos correctamente
        xlsx.Append('\uFEFF');
        xlsx.AppendLine("N°,Folio / Solicitante,Tipo,Límite,Estado");

        for (int i = 0; i < Eventos.Count; i++)
        {
            var e = Eventos[i];
            var dias = CalcularDiasHabiles(DateTime.Now.Date, e.End.Date);

            // Replicamos la lógica humana para el Excel
            string estadoTexto = "";
            if (dias < 0) estadoTexto = $"Venció hace {Math.Abs(dias)} días";
            else if (dias == 0) estadoTexto = "Vence hoy";
            else estadoTexto = $"Quedan {dias} días";

            xlsx.AppendLine($"{i + 1},\"{e.Title}\",\"{e.TipoSolicitud}\",\"{e.End:dd/MM/yyyy}\",\"{estadoTexto}\"");
        }

        var xlsxBytes = Encoding.UTF8.GetBytes(xlsx.ToString());
        var base64 = Convert.ToBase64String(xlsxBytes);
        await JS.InvokeVoidAsync("downloadFileFromBytes", nombre, base64);
    }

    private int CalcularDiasHabiles(DateTime inicio, DateTime fin)
    {
        int dias = 0;
        int signo = Math.Sign((fin - inicio).Days);
        if (signo == 0) return 0; // Evita ciclos infinitos si es hoy

        DateTime fecha = inicio;

        while (fecha != fin.AddDays(signo))
        {
            if (fecha.DayOfWeek != DayOfWeek.Saturday &&
                fecha.DayOfWeek != DayOfWeek.Sunday &&
                !diasFestivos.Contains(fecha.Date))
            {
                dias += signo;
            }
            fecha = fecha.AddDays(signo);
        }

        return dias;
    }

    private readonly List<DateTime> diasFestivos = new()
    {
        new DateTime(DateTime.Now.Year, 1, 1),
        new DateTime(DateTime.Now.Year, 2, 5),
        new DateTime(DateTime.Now.Year, 3, 21),
        new DateTime(DateTime.Now.Year, 5, 1),
        new DateTime(DateTime.Now.Year, 9, 16),
        new DateTime(DateTime.Now.Year, 11, 2),
        new DateTime(DateTime.Now.Year, 11, 20),
        new DateTime(DateTime.Now.Year, 12, 12),
        new DateTime(DateTime.Now.Year, 12, 24),
        new DateTime(DateTime.Now.Year, 12, 25),
        new DateTime(DateTime.Now.Year, 12, 31),
    };
}

<style>
    /* ================= CONTENEDOR PRINCIPAL ================= */
    .vencimiento-modal-container {
        font-family: 'Inter', system-ui, sans-serif;
        background-color: white;
    }

    .modal-header-actions {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid #f1f5f9;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .modal-title {
        font-size: 1.5rem;
        font-weight: 800;
        color: #0f172a;
        margin: 0 0 0.25rem 0;
        letter-spacing: -0.5px;
    }

    .modal-subtitle {
        color: #64748b;
        font-size: 0.9rem;
        margin: 0;
    }

    /* ================= BOTÓN EXPORTAR ================= */
