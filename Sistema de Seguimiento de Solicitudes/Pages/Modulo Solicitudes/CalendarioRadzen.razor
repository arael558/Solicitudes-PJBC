@page "/menu/modulo-solicitudes/Calendario"

@attribute [Authorize]

@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Authorization
@using Sistema_de_Seguimiento_de_Solicitudes.Models
@using Sistema_de_Seguimiento_de_Solicitudes.Services
@using Radzen
@using System.Text.Json
@using SolicitudesShared
@using System.Security.Claims

@inject DialogService DialogService
@inject IExpedienteService ExpedienteService
@inject ICalendarioService CalendarioService
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Calendario de Vencimientos</PageTitle>

<div class="page-container">
    <div class="header-flex">
        <h2 class="page-title">Calendario de Solicitudes</h2>
    </div>

    <div class="filters-action-bar">
        <div class="filters-group">
            <div class="toggle-group">
                <span class="text-muted fw-bold" style="font-size: 0.85rem; text-transform: uppercase;">Encabezado:</span>
                <RadzenSwitch @bind-Value="@showHeader" Style="margin-left: 10px;" />
            </div>

            <div class="v-divider"></div>

            @if (esAdminOSupervision)
            {
                <div class="filter-item-date d-flex align-items-center gap-2">
                    <RadzenDatePicker @bind-Value="@fechaSeleccionada"
                                      DateFormat="dd/MM/yyyy"
                                      Placeholder="Día laborable..."
                                      Class="pro-input" />

                    <button class="btn-action-outline" @onclick="ToggleDiaManual" title="Activar/Desactivar Día" style="height: 42px; width: 42px;">
                        <i class="bi bi-calendar-x"></i>
                    </button>
                </div>
            }
        </div>

        <div class="actions-group">
            <button class="btn-primary-pro" @onclick="MostrarEventosPorVencimiento">
                <i class="bi bi-exclamation-triangle-fill nav-icon" style="margin-right: 8px;"></i> Ver Próximos a Vencer
            </button>
        </div>
    </div>

    <div class="pro-table-card">
        <RadzenScheduler @ref="@scheduler"
                         SlotRender="@OnSlotRender"
                         style="height: calc(100vh - 280px); width: 100%; border: none;"
                         TItem="EventoSolicitud"
                         Data="@eventos"
                         StartProperty="Start"
                         EndProperty="End"
                         ShowHeader="@showHeader"
                         TextProperty="Title"
                         SelectedIndex="2"
                         AppointmentRender="@OnAppointmentRender">
            <RadzenDayView />
            <RadzenWeekView />
            <RadzenMonthView />
        </RadzenScheduler>
    </div>
</div>

@code {
    RadzenScheduler<EventoSolicitud>? scheduler;

    bool showHeader = true;

    private ClaimsPrincipal usuarioActual;
    private bool esAdminOSupervision;

    private List<EventoSolicitud> eventos = new List<EventoSolicitud>();

    DateTime? fechaSeleccionada;
    List<DateTime> diasApagadosManualmente = new();

    // Lista de días festivos
    private readonly List<DateTime> diasFestivos = new List<DateTime>
    {
        new DateTime(DateTime.Now.Year, 1, 1),
        new DateTime(DateTime.Now.Year, 2, 5),
        new DateTime(DateTime.Now.Year, 3, 21),
        new DateTime(DateTime.Now.Year, 5, 1),
        new DateTime(DateTime.Now.Year, 9, 16),
        new DateTime(DateTime.Now.Year, 11, 2),
        new DateTime(DateTime.Now.Year, 11, 20),
        new DateTime(DateTime.Now.Year, 12, 12),
        new DateTime(DateTime.Now.Year, 12, 25),
        new DateTime(DateTime.Now.Year, 12, 24),
        new DateTime(DateTime.Now.Year, 12, 31)
    };

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        usuarioActual = authState.User;

        esAdminOSupervision = usuarioActual.IsInRole("ADMINISTRADOR") || usuarioActual.IsInRole("SUPERVISIÓN");

        var expedienteList = await ExpedienteService.Lista();

        diasApagadosManualmente = (await CalendarioService.ObtenerDiasInhabiles())
            .Select(d => d.Fecha.Date)
            .ToList();

        eventos = MapearEventos(expedienteList);
    }

    // 🔥 MÉTODO SALVAVIDAS: Mapea eventos sin crashear si hay nulos 🔥
    private List<EventoSolicitud> MapearEventos(List<ExpedienteDTO> expedientes)
    {
        var listaEventos = new List<EventoSolicitud>();

        foreach (var expediente in expedientes.Where(e => e?.FechaInicio != null))
        {
            DateTime inicio = expediente.FechaInicio;
            DateTime fechaFin = inicio.AddDays(10); // Salvavidas: si todo falla, asume 10 días.

            if (expediente.Prevencion == true && expediente.FechaLimitePrevencion10dias.HasValue)
            {
                fechaFin = expediente.FechaLimitePrevencion10dias.Value;
            }
            else if (expediente.Ampliacion == "SI" && expediente.FechaLimiteRespuesta20dias.HasValue)
            {
                fechaFin = expediente.FechaLimiteRespuesta20dias.Value;
            }
            else if (expediente.FechaLimiteRespuesta10dias.HasValue)
            {
                fechaFin = expediente.FechaLimiteRespuesta10dias.Value;
            }
            else if (expediente.FechaLimiteRespuesta20dias.HasValue)
            {
                fechaFin = expediente.FechaLimiteRespuesta20dias.Value;
            }

            listaEventos.Add(new EventoSolicitud
            {
                Title = $"{expediente.Folio} – {expediente.NombreSolicitante}",
                Start = inicio,
                End = fechaFin,
                TipoSolicitud = expediente.TipoSolicitud ?? "",
                TienePrevencion = expediente.Prevencion,
                EsUrgente = false
            });
        }

        return listaEventos;
    }

    async Task ToggleDiaManual()
    {
        if (fechaSeleccionada.HasValue)
        {
            var fecha = fechaSeleccionada.Value.Date;

            if (diasApagadosManualmente.Contains(fecha))
            {
                diasApagadosManualmente.Remove(fecha);
                await CalendarioService.EliminarDiaInhabil(fecha);
            }
            else
            {
                diasApagadosManualmente.Add(fecha);
                await CalendarioService.GuardarDiaInhabil(new DiaInhabilManualDTO { Fecha = fecha });
            }

            var expedienteList = await ExpedienteService.Lista();
            diasApagadosManualmente = (await CalendarioService.ObtenerDiasInhabiles()).Select(d => d.Fecha.Date).ToList();

            eventos = MapearEventos(expedienteList);
            scheduler?.Reload();
        }
    }

    async Task MostrarEventosPorVencimiento()
    {
        var hoy = DateTime.Now.Date;

        var eventosVencidos = eventos
            .Where(e => CalcularDiasHabiles(hoy, e.End.Date) < 6)
            .OrderBy(e => CalcularDiasHabiles(hoy, e.End.Date))
            .ToList();

        await DialogService.OpenAsync<VerEventosVencimiento>("Vencimientos Críticos", new Dictionary<string, object>
        {
            { "Eventos", eventosVencidos }
        }, new DialogOptions { Width = "900px", Height = "650px", CssClass = "pro-dialog" });
    }

    private bool EsDiaLaborable(DateTime fecha)
    {
        return fecha.DayOfWeek != DayOfWeek.Saturday &&
               fecha.DayOfWeek != DayOfWeek.Sunday &&
               !diasFestivos.Contains(fecha.Date) &&
               !diasApagadosManualmente.Contains(fecha.Date);
    }

    private int CalcularDiasHabiles(DateTime inicio, DateTime fin)
    {
        int dias = 0;
        DateTime fecha = inicio;
        int step = fin >= inicio ? 1 : -1;
        DateTime endDate = fin.AddDays(step);

        while (fecha != endDate)
        {
            if (EsDiaLaborable(fecha)) dias += step;
            fecha = fecha.AddDays(step);
        }

        return Math.Abs(dias);
    }

    void OnAppointmentRender(SchedulerAppointmentRenderEventArgs<EventoSolicitud> args)
    {
        var fechaLimiteReal = args.Data.End.Date.AddDays(-1);
        var diasHabilesRestantes = CalcularDiasHabiles(DateTime.Now.Date, fechaLimiteReal);

        string tipo = args.Data.TipoSolicitud?.ToUpperInvariant()?.Trim() ?? "";
        string tipoClase = tipo switch
        {
            "ARCO" => "event-arco tooltip-arco",
            "DAI" => "event-dai tooltip-dai",
            "" => "event-sintipo tooltip-sintipo",
            _ => "event-especial"
        };

        string estadoClase = diasHabilesRestantes switch
        {
            var d when d < 0 => "event-gris",
            var d when d < 3 => "event-roja",
            var d when d < 6 => "event-amarilla",
            var d when d < 100 => "event-verde",
            _ => tipoClase
        };

        string tooltipClase = tipo switch
        {
            "ARCO" => "tooltip-arco",
            "DAI" => "tooltip-dai",
            "" => "tooltip-sintipo",
            _ => ""
        };

        args.Attributes["class"] = $"{estadoClase} tooltip-wrapper {tooltipClase} shadow-sm";

        args.Attributes["data-tooltip"] = $"{args.Data.Title}\n" +
                                          $"Tipo: {args.Data.TipoSolicitud}\n" +
                                          $"Inicio: {args.Data.Start:dd/MM/yyyy}\n" +
                                          $"Fin: {args.Data.End:dd/MM/yyyy}\n" +
                                          $"Días hábiles restantes: {diasHabilesRestantes}";
    }

    void OnSlotRender(SchedulerSlotRenderEventArgs args)
    {
        string clases = "";

        if (args.Start.Date == DateTime.Today.Date)
        {
            clases += " dia-actual";
        }

        if (!EsDiaLaborable(args.Start.Date) || diasApagadosManualmente.Contains(args.Start.Date))
        {
            clases += " rz-scheduler-non-working-time-cell";
        }

        if ((args.View.Text == "Week" || args.View.Text == "Day") &&
            args.Start.Hour > 8 && args.Start.Hour < 19)
        {
            args.Attributes["style"] = "background: rgba(79, 70, 229, 0.03);";
        }

        if (!string.IsNullOrWhiteSpace(clases))
        {
            args.Attributes["class"] = (args.Attributes.ContainsKey("class") ? args.Attributes["class"] + " " : "") + clases.Trim();
        }
    }
}

<style>
    /* ================= PALETA SaaS PRO ================= */
    :root {
        --pro-bg-body: #f1f5f9;
        --pro-card-bg: #ffffff;
        --pro-text-main: #1e293b;
        --pro-text-muted: #64748b;
        --pro-border: #e2e8f0;
        --pro-primary: #4f46e5;
    }

    .page-container {
        padding: 2rem;
        max-width: 1600px;
        margin: 0 auto;
        font-family: 'Inter', system-ui, sans-serif;
    }

    .header-flex {
        margin-bottom: 2rem;
    }

    .page-title {
        font-size: 1.75rem;
        font-weight: 800;
        color: var(--pro-text-main);
        margin: 0;
        letter-spacing: -0.025em;
    }

    /* ================= CONTROLES SUPERIORES ================= */
    .filters-action-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
    }

    .filters-group {
        display: flex;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
    }

    .toggle-group {
        display: flex;
        align-items: center;
        background: white;
        padding: 0.5rem 1rem;
        border-radius: 8px;
        border: 1px solid var(--pro-border);
    }

    .v-divider {
        width: 1px;
        height: 24px;
        background-color: var(--pro-border);
        margin: 0 4px;
    }

    /* Forzar estilo a los inputs de Radzen */
    .pro-input .rz-inputtext {
        height: 42px !important;
        border-radius: 8px !important;
        border: 1px solid var(--pro-border) !important;
        box-shadow: none !important;
        padding: 0 1rem !important;
    }

    .btn-action-outline {
        border-radius: 8px;
        border: 1px solid var(--pro-border);
        background: white;
        color: var(--pro-text-muted);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
    }

        .btn-action-outline:hover {
            color: var(--pro-primary);
            border-color: var(--pro-primary);
            background: #f5f3ff;
        }

    .btn-primary-pro {
        height: 42px;
        padding: 0 1.25rem;
        border-radius: 8px;
        border: none;
        background-color: var(--pro-primary);
        color: white;
        font-weight: 600;
        font-size: 0.9rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
        box-shadow: 0 4px 6px rgba(79, 70, 229, 0.2);
    }

        .btn-primary-pro:hover {
            background-color: #4338ca;
            transform: translateY(-1px);
        }

    /* ================= TARJETA DEL CALENDARIO ================= */
    .pro-table-card {
        background: var(--pro-card-bg);
        border-radius: 12px;
        border: 1px solid var(--pro-border);
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.03);
        overflow: hidden;
        padding: 1rem;
    }

    /* Purgar estilos viejos de Radzen */
    .rz-scheduler-header {
        border-bottom: 1px solid var(--pro-border) !important;
        background: transparent !important;
    }

    .rz-scheduler-nav {
        border: 1px solid var(--pro-border) !important;
        border-radius: 8px !important;
        overflow: hidden;
    }

    /* Dia actual */
    .dia-actual {
        background-color: rgba(79, 70, 229, 0.05) !important;
        border-left: 2px solid var(--pro-primary) !important;
        border-right: 2px solid var(--pro-primary) !important;
        z-index: 2;
    }

    /* Días inhabilitados con textura elegante */
    .rz-scheduler-non-working-time-cell {
        background-color: #f8fafc !important;
        position: relative;
    }

        .rz-scheduler-non-working-time-cell::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-image: repeating-linear-gradient(45deg, transparent, transparent 4px, rgba(0, 0, 0, 0.02) 4px, rgba(0, 0, 0, 0.02) 8px);
            pointer-events: none;
        }

    /* ================= COLORES DE EVENTOS PRO ================= */
    .rz-event {
        border-radius: 6px !important;
        border-left-width: 4px !important;
        border-left-style: solid !important;
        color: #1e293b !important;
        font-weight: 600 !important;
    }

    .event-verde {
        background-color: #d1fae5 !important;
        border-left-color: #059669 !important;
    }

    .event-amarilla {
        background-color: #fef3c7 !important;
        border-left-color: #d97706 !important;
    }

    .event-roja {
        background-color: #fee2e2 !important;
        border-left-color: #dc2626 !important;
    }

    .event-gris {
        background-color: #f1f5f9 !important;
        border-left-color: #64748b !important;
    }

    /* ================= TOOLTIPS ================= */
    .tooltip-wrapper {
        position: relative;
    }

        .tooltip-wrapper::after {
            content: attr(data-tooltip);
            position: absolute;
            bottom: 110%;
            left: 50%;
            transform: translateX(-50%);
            background-color: #0f172a;
            color: white;
            padding: 0.75rem;
            border-radius: 8px;
            font-size: 0.75rem;
            white-space: pre-line;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.2s;
            z-index: 1000;
            min-width: 250px;
            text-align: left;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
            line-height: 1.5;
            font-weight: 400;
        }

        .tooltip-wrapper::before {
            content: "";
            position: absolute;
            bottom: 100%;
            left: 50%;
            transform: translateX(-50%);
            border-width: 6px;
            border-style: solid;
            border-color: transparent transparent #0f172a transparent;
            opacity: 0;
            transition: opacity 0.2s;
            z-index: 999;
        }

        .tooltip-wrapper:hover::after, .tooltip-wrapper:hover::before {
            opacity: 1;
        }
</style>