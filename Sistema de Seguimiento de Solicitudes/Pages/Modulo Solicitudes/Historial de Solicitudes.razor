    /* Estilos de Celda específicos */
    .text-folio {
        font-weight: 700;
        color: var(--pro-primary);
    }

    .text-nombre {
        font-weight: 500;
        color: #334155;
    }

    .text-date {
        color: var(--pro-text-muted);
        font-size: 0.9rem;
    }

    .text-id {
        color: #cbd5e1;
        font-family: monospace;
        font-size: 0.8rem;
    }

    /* Empty State Moderno */
    .empty-state {
        text-align: center;
        padding: 5rem 2rem !important;
        color: var(--pro-text-muted);
    }

    .text-dark {
        color: var(--pro-text-main);
        font-weight: 600;
        font-size: 1.1rem;
    }

    .text-sm {
        font-size: 0.9rem;
    }

    /* ================= ACCIONES DE FILA PRO ================= */
    /* El botón redondo aparece solo en hover o es sutil */
    .btn-action-circle {
        width: 36px !important;
        height: 36px !important;
        border-radius: 50%;
        border: 1px solid var(--pro-border);
        background: var(--pro-card-bg);
        color: var(--pro-text-muted);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
        cursor: pointer;
        padding: 0 !important;
        opacity: 0.6; /* Sutil por defecto */
    }

    .pro-table tr:hover .btn-action-circle {
        opacity: 1;
        background: var(--pro-primary);
        color: white;
        border-color: var(--pro-primary);
        box-shadow: 0 2px 4px rgba(79, 70, 229, 0.2);
    }

    /* ================= BADGES MODERNOS (Soft Colors) ================= */
    .status-badge {
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        display: inline-block;
        white-space: nowrap;
        letter-spacing: 0.025em;
    }

    /* Colores PRO pastel/suaves con texto oscuro */
    .st-inicio {
        background: #dbeafe;
        color: #1e40af;
    }
    /* Azul */
    .st-proceso {
        background: #fee2e2;
        color: #991b1b;
    }
    /* Rojo suave */
    .st-prevencion {
        background: #fef3c7;
        color: #854d0e;
