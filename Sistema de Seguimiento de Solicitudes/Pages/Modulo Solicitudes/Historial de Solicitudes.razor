        box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1);
    }

    .v-divider {
        width: 1px;
        height: 24px;
        background-color: var(--pro-border);
        margin: 0 4px;
    }

    .text-uppercase {
        text-transform: uppercase;
    }

    /* Botón Excel Pro */
    /* !important para asegurar el control de ancho */
