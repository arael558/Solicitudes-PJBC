        }

        .modern-table tr:hover {
            background: #f8fafc;
        }

    .text-id {
        color: var(--text-light);
        font-family: monospace;
        font-size: 0.85rem;
    }

    .user-info {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .user-avatar {
