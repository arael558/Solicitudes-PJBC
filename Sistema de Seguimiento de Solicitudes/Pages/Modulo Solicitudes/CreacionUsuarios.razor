        align-items: center;
        justify-content: center;
        font-weight: 700;
        color: #475569;
        font-size: 0.8rem;
    }

    .text-nombre {
        font-weight: 600;
        color: #334155;
    }

    .empty-state {
        text-align: center;
        padding: 4rem !important;
        color: var(--text-light);
