    }

    .scroll-container::-webkit-scrollbar-thumb {
        background-color: #cbd5e1;
        border-radius: 10px;
        border: 2px solid transparent;
        background-clip: padding-box;
    }

        .scroll-container::-webkit-scrollbar-thumb:hover {
            background-color: #94a3b8;
        }
</style>