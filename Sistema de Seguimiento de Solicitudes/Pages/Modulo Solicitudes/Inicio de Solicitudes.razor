@page "/menu/modulo-solicitudes/inicio-solicitudes"

@attribute [Authorize]

@using Microsoft.AspNetCore.Authorization
@using System.Collections.Generic
@using SolicitudesShared
@using MudBlazor
@using Sistema_de_Seguimiento_de_Solicitudes.Services
@using System.Text.Json
@using Sistema_de_Seguimiento_de_Solicitudes.Models
@using Microsoft.AspNetCore.Components.Authorization

@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject IExpedienteService ExpedienteService
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Inicio - Panel de Solicitudes</PageTitle>

<div class="dashboard-wrapper">
    <div class="header-section mb-8">
        <div class="header-content">
            <h1 class="dashboard-title">Panel de Control</h1>
            <p class="dashboard-subtitle">Monitoreo en tiempo real del estado y vigencia de las solicitudes</p>
        </div>
    </div>

    <div class="dashboard-container">
        <MudGrid Spacing="4" Justify="Justify.Center">

            <MudItem xs="12" sm="6" md="3">
                <div class="status-card border-slate @(isVisible[4] ? "active" : "")" @onclick="@(() => ToggleVisibility(4))">
                    <div class="card-icon bg-slate-light icon-slate">
                        <MudIcon Icon="@Icons.Material.Filled.HistoryToggleOff" />
                    </div>
                    <div class="card-info">
                        <span class="count-text text-slate">@solicitudesGrises.Count</span>
                        <span class="status-label">Vencidas</span>
                    </div>
                    <MudIcon Icon="@(isVisible[4] ? Icons.Material.Filled.KeyboardArrowUp : Icons.Material.Filled.KeyboardArrowDown)" Class="expand-icon" />
                </div>
                @if (isVisible[4])
                {
                    <div class="list-dropdown">@RenderList(solicitudesGrises, "slate")</div>
                }
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <div class="status-card border-rose @(isVisible[2] ? "active" : "")" @onclick="@(() => ToggleVisibility(2))">
                    <div class="card-icon bg-rose-light icon-rose pulse-animation">
                        <MudIcon Icon="@Icons.Material.Filled.CrisisAlert" />
                    </div>
                    <div class="card-info">
                        <span class="count-text text-rose">@solicitudesRojas.Count</span>
                        <span class="status-label">Menos de 2 días</span>
                    </div>
                    <MudIcon Icon="@(isVisible[2] ? Icons.Material.Filled.KeyboardArrowUp : Icons.Material.Filled.KeyboardArrowDown)" Class="expand-icon" />
                </div>
                @if (isVisible[2])
                {
                    <div class="list-dropdown">@RenderList(solicitudesRojas, "rose")</div>
                }
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <div class="status-card border-amber @(isVisible[1] ? "active" : "")" @onclick="@(() => ToggleVisibility(1))">
                    <div class="card-icon bg-amber-light icon-amber">
                        <MudIcon Icon="@Icons.Material.Filled.NotificationsActive" />
                    </div>
                    <div class="card-info">
                        <span class="count-text text-amber">@solicitudesAmarillas.Count</span>
                        <span class="status-label">Menos de 5 días</span>
                    </div>
                    <MudIcon Icon="@(isVisible[1] ? Icons.Material.Filled.KeyboardArrowUp : Icons.Material.Filled.KeyboardArrowDown)" Class="expand-icon" />
                </div>
                @if (isVisible[1])
                {
                    <div class="list-dropdown">@RenderList(solicitudesAmarillas, "amber")</div>
                }
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <div class="status-card border-emerald @(isVisible[0] ? "active" : "")" @onclick="@(() => ToggleVisibility(0))">
                    <div class="card-icon bg-emerald-light icon-emerald">
                        <MudIcon Icon="@Icons.Material.Filled.VerifiedUser" />
                    </div>
                    <div class="card-info">
                        <span class="count-text text-emerald">@solicitudesVerdes.Count</span>
                        <span class="status-label">Mayor a 6 días</span>
                    </div>
                    <MudIcon Icon="@(isVisible[0] ? Icons.Material.Filled.KeyboardArrowUp : Icons.Material.Filled.KeyboardArrowDown)" Class="expand-icon" />
                </div>
                @if (isVisible[0])
                {
                    <div class="list-dropdown">@RenderList(solicitudesVerdes, "emerald")</div>
                }
            </MudItem>

        </MudGrid>
    </div>
</div>

@code {
    private RenderFragment RenderList(List<Expediente> lista, string theme) => __builder =>
    {
        <div class="scroll-container">
            @if (lista.Count == 0)
            {
                <div class="empty-state">
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Class="empty-icon mb-2 opacity-50" />
                    <p>Bandeja limpia. No hay solicitudes aquí.</p>
                </div>
            }
            else
            {
                <div class="list-wrapper">
                    @foreach (var solicitud in lista)
                    {
                        int diasRestantes = GetTiempoRestante(solicitud.FechaInicioTramite);
                        string badgeClass = theme == "slate" ? "badge-slate" :
                        theme == "rose" ? "badge-rose" :
                        theme == "amber" ? "badge-amber" : "badge-emerald";
                        string diasTexto = diasRestantes < 0 ? "Vencida" : $"{diasRestantes}d restantes";

                        <div class="list-item" @onclick="(() => RedirigirADetalles(solicitud.Id))">
                            <div class="item-main">
                                <div class="item-header">
                                    <span class="item-folio">
                                        <MudIcon Icon="@Icons.Material.Filled.Article" Class="small-icon mr-2 text-muted-icon" />
                                        @solicitud.Folio
                                    </span>
                                    <span class="status-badge @badgeClass">@diasTexto</span>
                                </div>
                                <div class="item-body">
                                    <span class="item-name" title="@solicitud.Nombre">@solicitud.Nombre</span>
                                </div>
                                <div class="item-footer">
                                    <span class="item-date">
                                        <MudIcon Icon="@Icons.Material.Filled.Event" Class="small-icon mr-1 inline-icon" />
                                        Iniciado: @solicitud.FechaInicioTramite.ToString("dd MMM yyyy")
                                    </span>
                                </div>
                            </div>
                            <div class="item-action">
                                <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Class="chevron-right" />
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    };

    private bool[] isVisible = new bool[5];
    private List<Expediente> solicitudesGrises = new();
    private List<Expediente> solicitudesRojas = new();
    private List<Expediente> solicitudesAmarillas = new();
    private List<Expediente> solicitudesVerdes = new();

    List<ExpedienteDTO>? listaExpedientes = null;

    protected override async Task OnInitializedAsync()
    {
        listaExpedientes = await ExpedienteService.Lista();
        ClasificarSolicitudes();
    }

    private void ClasificarSolicitudes()
    {
        solicitudesGrises.Clear(); solicitudesRojas.Clear();
        solicitudesAmarillas.Clear(); solicitudesVerdes.Clear();

        if (listaExpedientes != null)
        {
            foreach (var dto in listaExpedientes)
            {
                var exp = new Expediente
                {
                    Id = dto.Id,
                    Folio = dto.Folio ?? "S/F",
                    Nombre = dto.NombreSolicitante ?? "Sin nombre registrado",
                    FechaInicioTramite = dto.FechaInicio,
                    Estatus = dto.Estado ?? ""
                };

                if (exp.FechaInicioTramite != DateTime.MinValue)
                {
                    int diasRestantes = GetTiempoRestante(exp.FechaInicioTramite);
                    if (diasRestantes < 0) solicitudesGrises.Add(exp);
                    else if (diasRestantes < 3) solicitudesRojas.Add(exp);
                    else if (diasRestantes < 6) solicitudesAmarillas.Add(exp);
                    else solicitudesVerdes.Add(exp);
                }
            }
        }
    }

    private int GetTiempoRestante(DateTime? fechaInicio)
    {
        if (!fechaInicio.HasValue) return 0;
        DateTime fechaVencimiento = fechaInicio.Value.AddDays(30);
        return (fechaVencimiento.Date - DateTime.Now.Date).Days;
    }

    private void ToggleVisibility(int index) => isVisible[index] = !isVisible[index];

    private void RedirigirADetalles(int id)
    {
        var exp = listaExpedientes?.FirstOrDefault(e => e.Id == id);
        if (exp != null) Navigation.NavigateTo($"/menu/modulo-solicitudes/indice-expedientes/detalles/{id}/{exp.Folio}");
    }
}

<style>
    :root {
        --bg-body: #f4f7f9;
        --card-bg: #ffffff;
        --text-primary: #0f172a;
        --text-secondary: #64748b;
        --border-light: #e2e8f0;
        --slate-500: #64748b;
        --slate-800: #1e293b;
        --slate-50: #f8fafc;
        --rose-500: #f43f5e;
        --rose-600: #e11d48;
        --rose-50: #fff1f2;
        --amber-500: #f59e0b;
        --amber-600: #d97706;
        --amber-50: #fffbeb;
        --emerald-500: #10b981;
        --emerald-600: #059669;
        --emerald-50: #ecfdf5;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
    }

    .dashboard-wrapper {
        padding: 2rem 1rem;
        font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
        background-color: transparent;
    }

    .header-section {
        margin-bottom: 2.5rem;
        position: relative;
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--border-light);
    }

    .dashboard-title {
        font-weight: 800;
        font-size: 2.25rem;
        color: var(--text-primary);
        letter-spacing: -0.025em;
        margin-bottom: 0.25rem;
    }

    .dashboard-subtitle {
        color: var(--text-secondary);
        font-size: 1.05rem;
        font-weight: 400;
    }

    /* FIX DEFINITIVO PARA FLEXBOX Y TAMAÑOS */
    .status-card {
        background: var(--card-bg);
        border-radius: 16px;
        padding: 1.25rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 16px;
        position: relative;
        cursor: pointer;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid var(--border-light);
        box-shadow: var(--shadow-sm);
        user-select: none;
        overflow: hidden;
    }

        .status-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            bottom: 0;
            width: 6px;
            border-top-left-radius: 16px;
            border-bottom-left-radius: 16px;
            transition: width 0.2s;
        }

        .status-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--shadow-lg);
            border-color: transparent;
        }

            .status-card:hover::before {
                width: 8px;
            }

        .status-card.active {
            border-bottom-left-radius: 0;
            border-bottom-right-radius: 0;
            border-bottom-color: transparent;
            box-shadow: var(--shadow-md);
            transform: none;
            z-index: 10;
        }

            .status-card.active::before {
                border-bottom-left-radius: 0;
            }

    .border-slate::before {
        background-color: var(--slate-500);
    }

    .border-rose::before {
        background-color: var(--rose-500);
    }

    .border-amber::before {
        background-color: var(--amber-500);
    }

    .border-emerald::before {
        background-color: var(--emerald-500);
    }

    /* CANDADOS DE TAMAÑO PARA ICONOS PRINCIPALES */
    .card-icon {
        flex-shrink: 0 !important;
        width: 52px !important;
        height: 52px !important;
        min-width: 52px !important;
        min-height: 52px !important;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.3s ease;
    }

        .card-icon svg {
            width: 28px !important;
            height: 28px !important;
        }

    .status-card:hover .card-icon {
        transform: scale(1.05) rotate(-3deg);
    }

    .bg-slate-light {
        background-color: var(--slate-50);
    }

    .bg-rose-light {
        background-color: var(--rose-50);
    }

    .bg-amber-light {
        background-color: var(--amber-50);
    }

    .bg-emerald-light {
        background-color: var(--emerald-50);
    }

    .icon-slate {
        color: var(--slate-500);
    }

    .icon-rose {
        color: var(--rose-600);
    }

    .icon-amber {
        color: var(--amber-600);
    }

    .icon-emerald {
        color: var(--emerald-600);
    }

    @@keyframes pulseRed {
        0% {
            box-shadow: 0 0 0 0 rgba(244, 63, 94, 0.4);
        }

        70% {
            box-shadow: 0 0 0 10px rgba(244, 63, 94, 0);
        }

        100% {
            box-shadow: 0 0 0 0 rgba(244, 63, 94, 0);
        }
    }

    .pulse-animation {
        animation: pulseRed 2s infinite;
    }

    /* CANDADO PARA TEXTOS LARGOS QUE ROMPEN EL FLEX */
    .card-info {
        display: flex;
        flex-direction: column;
        flex-grow: 1;
        min-width: 0 !important; /* CRÍTICO para que no empuje a los lados */
    }

    .count-text {
        font-size: 2rem;
        font-weight: 800;
        line-height: 1;
        letter-spacing: -0.05em;
    }

    .text-slate {
        color: var(--slate-800);
    }

    .text-rose {
        color: var(--rose-600);
    }

    .text-amber {
        color: var(--amber-600);
    }

    .text-emerald {
        color: var(--emerald-600);
    }

    .status-label {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-top: 4px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    /* CANDADO DE TAMAÑO PARA FLECHA DE EXPANSIÓN */
    .expand-icon {
        flex-shrink: 0 !important;
        width: 24px !important;
        height: 24px !important;
        min-width: 24px !important;
        min-height: 24px !important;
        color: var(--text-secondary);
        transition: transform 0.3s ease, color 0.2s;
        opacity: 0.5;
    }

        .expand-icon svg {
            width: 24px !important;
            height: 24px !important;
        }

    .status-card:hover .expand-icon {
        opacity: 1;
        color: var(--text-primary);
    }

    /* CANDADOS PARA ICONOS DE LA LISTA INTERNA */
    .small-icon {
        flex-shrink: 0 !important;
        width: 18px !important;
        height: 18px !important;
    }

        .small-icon svg {
            width: 18px !important;
            height: 18px !important;
        }

    .chevron-right {
        flex-shrink: 0 !important;
        width: 24px !important;
        height: 24px !important;
        color: #cbd5e1;
        transition: transform 0.2s, color 0.2s;
    }

        .chevron-right svg {
            width: 24px !important;
            height: 24px !important;
        }

    .empty-icon {
        width: 48px !important;
        height: 48px !important;
    }

        .empty-icon svg {
            width: 48px !important;
            height: 48px !important;
        }

    .list-dropdown {
        background: var(--card-bg);
        border: 1px solid var(--border-light);
        border-top: 1px solid #f1f5f9;
        border-bottom-left-radius: 16px;
        border-bottom-right-radius: 16px;
        box-shadow: var(--shadow-lg);
        overflow: hidden;
        animation: slideDownFade 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        transform-origin: top;
        position: relative;
        z-index: 9;
    }

    @@keyframes slideDownFade {
        from {
            opacity: 0;
            transform: scaleY(0.95) translateY(-10px);
        }

        to {
            opacity: 1;
            transform: scaleY(1) translateY(0);
        }
    }

    .scroll-container {
        max-height: 320px;
        overflow-y: auto;
        padding: 0.5rem;
    }

    .list-item {
        display: flex;
        align-items: center;
        padding: 1rem;
        margin: 0.5rem;
        border-radius: 12px;
        background-color: #ffffff;
        border: 1px solid transparent;
        cursor: pointer;
        transition: all 0.2s ease;
    }

        .list-item:hover {
            background-color: #f8fafc;
